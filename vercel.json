{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install --ignore-scripts",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://menuar-2.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://menuar-2.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api/|uploads/).*)",
      "destination": "/index.html"
    }
  ]
}