{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install --ignore-scripts",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://menuar-2.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://menuar-2.onrender.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}