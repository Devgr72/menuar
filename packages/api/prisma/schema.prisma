generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  free
  starter
  pro
}

enum ModelStatus {
  pending
  bg_removing
  bg_done
  generating_3d
  compressing
  ready
  failed
}

enum ModelSource {
  procedural
  tripo
  hunyuan
}

enum SubscriptionStatus {
  pending
  active
  halted
  cancelled
  expired
}

enum PaymentEventType {
  subscription_activated
  subscription_charged
  subscription_halted
  subscription_cancelled
  subscription_completed
  payment_failed
}

enum SlotStatus {
  empty
  photos_uploaded
  processing
  glb_ready
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Restaurant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(free)
  qrKey     String?  // R2 key for restaurant-level QR code image
  qrUrl     String?  // CDN URL for restaurant-level QR code
  scanCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        RestaurantOwner?
  subscription Subscription?
  slots        DishSlot[]
  tables       Table[]
  menus        Menu[]
}

model RestaurantOwner {
  id           String   @id @default(uuid())
  userId       String   @unique   // references User.id from Better Auth
  ownerName    String
  email        String?
  restaurantId String   @unique
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

// ─── Better Auth Models ───────────────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  sessions Session[]
  accounts Account[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

model Subscription {
  id              String             @id @default(uuid())
  restaurantId    String             @unique
  razorpaySubId   String             @unique
  razorpayPlanId  String
  status          SubscriptionStatus @default(pending)
  amount          Int                // in paise (50000 = ₹500)
  activatedAt     DateTime?
  nextBillingAt   DateTime?
  cancelledAt     DateTime?
  haltedAt        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  restaurant Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  events     PaymentEvent[]
}

model PaymentEvent {
  id              String           @id @default(uuid())
  subscriptionId  String
  eventType       PaymentEventType
  razorpayEventId String           @unique
  payload         Json
  createdAt       DateTime         @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model DishSlot {
  id           String     @id @default(uuid())
  restaurantId String
  slotNumber   Int        // 1-10
  dishName     String?    // set after admin processes
  description  String?
  ingredients  String?
  price        Float?
  isVeg        Boolean    @default(true)
  status       SlotStatus @default(empty)
  menuPhotoKey String?    // R2 key of the single menu/card thumbnail photo
  menuPhotoUrl String?    // CDN URL of menu thumbnail (shown on menu card)
  photoKeys    String[]   // R2 keys of 3D-angle photos (up to 4, for model gen)
  glbKey       String?    // R2 key of final GLB
  glbUrl       String?    // CDN URL
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, slotNumber])
}

model Table {
  id           String @id @default(uuid())
  restaurantId String
  tableNumber  Int
  qrCode       String @unique
  qrUrl        String

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  views      DishView[]
  qrCodes    QrCode[]

  @@unique([restaurantId, tableNumber])
}

model Menu {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categories Category[]
}

model Category {
  id        String @id @default(uuid())
  menuId    String
  name      String
  sortOrder Int    @default(0)

  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  dishes Dish[]
}

model Dish {
  id            String      @id @default(uuid())
  categoryId    String
  name          String
  description   String      @default("")
  price         Float
  isVeg         Boolean     @default(false)
  spiceLevel    Int         @default(0) // 0=none 1=mild 2=medium 3=hot
  allergens     String[]
  isAvailable   Boolean     @default(true)
  modelUrl      String?     // R2 CDN URL — set when modelStatus = ready
  thumbnailUrl  String?     // R2 CDN URL of cleaned dish photo
  modelStatus   ModelStatus @default(pending)
  modelSource   ModelSource @default(procedural)
  aiDescription String?
  translations  Json        @default("{}")
  createdAt     DateTime    @default(now())

  category Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  views    DishView[]
  photos   DishPhoto[]
}

model DishPhoto {
  id          String   @id @default(uuid())
  dishId      String
  originalKey String   // R2 object key — original upload
  cleanedKey  String?  // R2 object key — after bg removal
  createdAt   DateTime @default(now())

  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)
}

model DishView {
  id       String   @id @default(uuid())
  dishId   String
  tableId  String
  viewedAt DateTime @default(now())

  dish  Dish  @relation(fields: [dishId], references: [id], onDelete: Cascade)
  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)
}

model QrCode {
  id        String   @id @default(uuid())
  tableId   String
  imageKey  String   // R2 object key
  imageUrl  String   // R2 CDN public URL
  scanCount Int      @default(0)
  createdAt DateTime @default(now())

  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)
}
