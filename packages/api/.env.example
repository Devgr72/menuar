# Database (Neon/Postgres)
DATABASE_URL=

# ── Better Auth ─────────────────────────────────────────────────────────────
# Random 32-char secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your_32_char_secret_here

# ── Google OAuth (Better Auth social login) ──────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── SMTP (Better Auth email verification) ────────────────────────────────────
# Leave blank in dev — verification URL logs to console instead
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@dishdekho.app

# ── Admin JWT ────────────────────────────────────────────────────────────────
ADMIN_EMAILS=your@email.com
ADMIN_PASSWORD=
JWT_SECRET=your_jwt_secret

# ── Razorpay ────────────────────────────────────────────────────────────────
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
# Optional: cache the plan ID after first creation so you don't recreate on restart
RAZORPAY_PLAN_ID=plan_xxxx

# ── Cloudflare R2 ───────────────────────────────────────────────────────────
# Get from: dash.cloudflare.com → R2 → Manage R2 API tokens
CLOUDFLARE_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=menuar-models
# R2 public URL — enable public access on the bucket, copy the public URL
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
# Set to true to use R2 instead of local disk
USE_R2=false

# ── Third-Party APIs ─────────────────────────────────────────────────────────
REMOVE_BG_API_KEY=
TRIPO_API_KEY=
HUGGINGFACE_API_TOKEN=

# ── Server Config ────────────────────────────────────────────────────────────
PORT=3001
# API_URL is the base backend URL (e.g. https://menuar-2.onrender.com)
API_URL=
# WEB_URL is the base frontend URL (e.g. https://menuar-web.vercel.app)
WEB_URL=
