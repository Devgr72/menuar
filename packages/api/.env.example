# ── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Get from: console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Cloudflare R2 ───────────────────────────────────────────────────────────
# Get from: dash.cloudflare.com → R2 → Manage R2 API tokens
CLOUDFLARE_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=menuar-models
# R2 public URL — enable public access on the bucket, copy the public URL
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Background removal ──────────────────────────────────────────────────────
# Get from: remove.bg → Account → API keys (50 free/month)
REMOVE_BG_API_KEY=your_remove_bg_key

# ── 3D model generation ─────────────────────────────────────────────────────
# Get from: tripo3d.ai → Dashboard → API keys (free tier available)
TRIPO_API_KEY=your_tripo_key

# HuggingFace (optional — raises rate limits on free Spaces)
# Get from: huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
WEB_URL=http://localhost:3000
BASE_URL=http://localhost:3000
