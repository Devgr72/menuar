# Database (Neon/Postgres)
DATABASE_URL=

# Cloudflare R2 (Optional - Set USE_R2 to true if configured)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
USE_R2=false

# Third-Party APIs
REMOVE_BG_API_KEY=
TRIPO_API_KEY=
HUGGINGFACE_API_TOKEN=

# Server Config
PORT=3001
# API_URL is the base backend URL (e.g. https://menuar-2.onrender.com)
API_URL=
# WEB_URL is the base frontend URL (e.g. https://menuar-web.vercel.app)
WEB_URL=

# Admin Credentials (JWT Bearer Auth)
ADMIN_EMAILS=
ADMIN_PASSWORD=
JWT_SECRET=

# Better Auth (Google OAuth)
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID=
