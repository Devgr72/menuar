{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "build/**"
      ],
      "env": [
        "VITE_API_URL",
        "VITE_CLERK_PUBLISHABLE_KEY",
        "VITE_RAZORPAY_KEY_ID",
        "VITE_ADMIN_EMAILS",
        "VITE_MINDAR_LICENSE"
      ]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}