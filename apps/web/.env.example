# Clerk — get from dashboard.clerk.com → your app → API Keys → Publishable key
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxx

# API URL — backend URL (empty = use proxy at localhost:3001)
VITE_API_URL=http://localhost:3001

# Razorpay public key (safe to expose in frontend)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxx

# Admin emails — comma-separated, used for client-side /admin route guard
VITE_ADMIN_EMAILS=your@email.com

# Mind AR license (optional, for image tracking mode)
VITE_MINDAR_LICENSE=
