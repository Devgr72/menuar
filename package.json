{
  "name": "menuar",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --filter=@menuar/web && cp -r apps/web/dist ./dist",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "npm@10.8.1",
  "overrides": {
    "three": "0.149.0"
  },
  "dependencies": {
    "vercel": "^51.3.0"
  }
}
